<!DOCTYPE html>
<html lang="zh-CN">
<head>
    <meta charset="UTF-8">
    <title>hooks1的个人网站</title>
    <meta name="viewport" content="width=device-width, initial-scale=1.0, viewport-fit=cover">
    <meta name="description" content="hooks1的个人网站 - 分享技术心得与创作成果">
    <meta name="theme-color" content="#121212">
    
    <link rel="icon" href="data:image/svg+xml,<svg xmlns=%22http://www.w3.org/2000/svg%22 viewBox=%220 0 100 100%22><text y=%22.9em%22 font-size=%2290%22>🎮</text></svg>">
    
    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
    <link href="https://fonts.googleapis.com/css2?family=Noto+Sans+SC:wght@400;700&family=Roboto:wght@400;700&display=swap" rel="stylesheet">
    <link href="https://fonts.googleapis.com/css2?family=Material+Symbols+Rounded:opsz,wght,FILL,GRAD@24,400,0,0" rel="stylesheet">

    <style>
        :root {
            --font-main: 'Roboto', 'Noto Sans SC', system-ui, -apple-system, sans-serif;
            --radius: 16px;
            --transition: cubic-bezier(0.25, 0.46, 0.45, 0.94);
            
            /* Dark Theme (Default) */
            --bg-color: #121212;
            --text-primary: #E1E1E1;
            --text-secondary: #A0A0A0;
            --surface: rgba(30, 30, 30, 0.65);
            --surface-hover: rgba(45, 45, 45, 0.8);
            --border: rgba(255, 255, 255, 0.1);
            --primary-accent: #64B5F6;
            --header-bg: rgba(18, 18, 18, 0.8);
            --shadow: 0 4px 20px rgba(0,0,0,0.3);
        }

        /* Light Theme Variables */
        [data-theme="light"] {
            --bg-color: #F5F7FA;
            --text-primary: #2D3748;
            --text-secondary: #718096;
            --surface: rgba(255, 255, 255, 0.75);
            --surface-hover: rgba(255, 255, 255, 0.95);
            --border: rgba(0, 0, 0, 0.08);
            --primary-accent: #3182CE;
            --header-bg: rgba(245, 247, 250, 0.85);
            --shadow: 0 4px 20px rgba(0,0,0,0.08);
        }

        * { box-sizing: border-box; }

        body {
            font-family: var(--font-main);
            line-height: 1.6;
            margin: 0;
            min-height: 100vh;
            display: flex;
            flex-direction: column;
            background: var(--bg-color);
            color: var(--text-primary);
            transition: background-color 0.3s ease, color 0.3s ease;
            overflow-x: hidden;
        }

        /* Canvas Background */
        #bg-canvas {
            position: fixed;
            top: 0;
            left: 0;
            width: 100%;
            height: 100%;
            z-index: -1;
            pointer-events: auto; /* Allow mouse interaction */
        }

        /* Header & Nav */
        header {
            position: sticky;
            top: 0;
            z-index: 100;
            background: var(--header-bg);
            backdrop-filter: blur(16px) saturate(180%);
            -webkit-backdrop-filter: blur(16px) saturate(180%);
            border-bottom: 1px solid var(--border);
            padding: 0.5rem 1rem;
        }

        .nav-container {
            max-width: 1200px;
            margin: 0 auto;
            display: flex;
            justify-content: space-between;
            align-items: center;
            padding: 0.5rem;
        }

        h1 {
            font-size: 1.25rem;
            margin: 0;
            font-weight: 700;
            background: linear-gradient(45deg, var(--text-primary), var(--text-secondary));
            -webkit-background-clip: text;
            -webkit-text-fill-color: transparent;
        }

        .nav-group {
            display: flex;
            gap: 0.5rem;
            align-items: center;
        }

        .btn-icon {
            background: transparent;
            border: none;
            color: var(--text-primary);
            padding: 8px;
            border-radius: 50%;
            cursor: pointer;
            transition: background 0.2s;
            display: flex;
            align-items: center;
            justify-content: center;
        }

        .btn-icon:hover {
            background: var(--border);
        }

        /* Main Content */
        main {
            flex: 1;
            width: min(92%, 1000px);
            margin: 2rem auto;
            display: flex;
            flex-direction: column;
            gap: 2rem;
        }

        section {
            background: var(--surface);
            border-radius: var(--radius);
            padding: 2rem;
            border: 1px solid var(--border);
            backdrop-filter: blur(12px);
            box-shadow: var(--shadow);
            transition: transform 0.3s var(--transition);
        }

        h2 {
            margin-top: 0;
            font-size: 1.5rem;
            border-bottom: 2px solid var(--border);
            padding-bottom: 0.5rem;
            margin-bottom: 1.5rem;
        }

        /* Cards Grid */
        .links-grid {
            display: grid;
            grid-template-columns: repeat(auto-fit, minmax(280px, 1fr));
            gap: 1.5rem;
        }

        .card-link {
            display: flex;
            flex-direction: column;
            text-decoration: none;
            color: var(--text-primary);
            background: rgba(255,255,255,0.03);
            border: 1px solid var(--border);
            border-radius: var(--radius);
            padding: 1.5rem;
            transition: all 0.3s var(--transition);
            position: relative;
            overflow: hidden;
        }

        .card-link:hover {
            background: var(--surface-hover);
            transform: translateY(-5px);
            border-color: var(--primary-accent);
            box-shadow: 0 8px 24px rgba(0,0,0,0.15);
        }

        .card-header {
            display: flex;
            align-items: center;
            gap: 0.75rem;
            margin-bottom: 0.5rem;
            font-weight: bold;
            font-size: 1.1rem;
            color: var(--primary-accent);
        }

        .card-desc {
            font-size: 0.9rem;
            color: var(--text-secondary);
        }

        .icon-external {
            position: absolute;
            top: 1rem;
            right: 1rem;
            opacity: 0.3;
            transition: opacity 0.3s;
        }

        .card-link:hover .icon-external {
            opacity: 1;
            color: var(--primary-accent);
        }

        /* Footer */
        footer {
            text-align: center;
            padding: 2rem;
            color: var(--text-secondary);
            font-size: 0.9rem;
        }

        /* Utilities */
        .material-symbols-rounded {
            font-size: 24px;
        }
        
        /* Progress Bar */
        .progress-container {
            position: fixed;
            top: 0;
            left: 0;
            width: 100%;
            height: 3px;
            z-index: 9999;
            pointer-events: none;
        }
        
        .progress-bar {
            height: 100%;
            background: var(--primary-accent);
            width: 0;
            transition: width 0.2s ease;
            box-shadow: 0 0 10px var(--primary-accent);
        }

        @media (max-width: 600px) {
            section { padding: 1.5rem; }
            .links-grid { grid-template-columns: 1fr; }
        }
    </style>
</head>

<body>
    <canvas id="bg-canvas"></canvas>

    <div class="progress-container">
        <div class="progress-bar" id="progress-bar"></div>
    </div>

    <header>
        <div class="nav-container">
            <h1>hooks1</h1>
            <div class="nav-group">
                <button class="btn-icon" id="theme-toggle" aria-label="切换主题">
                    <span class="material-symbols-rounded">light_mode</span>
                </button>
                <a href="https://space.bilibili.com/1312125285" target="_blank" class="btn-icon" aria-label="Bilibili">
                    <span class="material-symbols-rounded">smart_display</span>
                </a>
            </div>
        </div>
    </header>

    <main>
        <section id="about">
            <h2>
                <span class="material-symbols-rounded" style="vertical-align: -4px; margin-right: 8px;">face</span>
                关于我
            </h2>
            <p style="font-size: 1.1rem; color: var(--text-secondary);">
                我是 <strong>hooks1</strong>，一个热衷于创作的视频 UP 主，也是一名《冰与火之舞》玩家。
                在这里分享我的技术心得与游戏生活。
            </p>
        </section>

        <section id="links">
            <h2>
                <span class="material-symbols-rounded" style="vertical-align: -4px; margin-right: 8px;">link</span>
                个人账号
            </h2>
            <div class="links-grid">
                <a href="https://space.bilibili.com/1312125285" target="_blank" rel="noopener noreferrer" class="card-link">
                    <span class="material-symbols-rounded icon-external">open_in_new</span>
                    <div class="card-header">
                        <span class="material-symbols-rounded">play_circle</span>
                        BiliBili 频道
                    </div>
                    <div class="card-desc">浏览我的视频作品，分享游戏与技术瞬间。</div>
                </a>

                <a href="https://music.163.com/user/home?id=3307535618" target="_blank" rel="noopener noreferrer" class="card-link">
                    <span class="material-symbols-rounded icon-external">open_in_new</span>
                    <div class="card-header">
                        <span class="material-symbols-rounded">music_note</span>
                        网易云音乐
                    </div>
                    <div class="card-desc">探索我的音乐收藏，感受旋律的共鸣。</div>
                </a>
            </div>
        </section>
    </main>

    <footer>
        <p>&copy; <span id="current-year"></span> hooks1 版权所有</p>
    </footer>

    <script>
        /**
         * Theme Management
         */
        const themeToggle = document.getElementById('theme-toggle');
        const icon = themeToggle.querySelector('span');
        
        function setTheme(theme) {
            document.documentElement.setAttribute('data-theme', theme);
            localStorage.setItem('theme', theme);
            icon.textContent = theme === 'light' ? 'dark_mode' : 'light_mode';
            
            // Update particle color based on theme
            if (window.particleSystem) {
                window.particleSystem.color = theme === 'light' ? 'rgba(0,0,0,0.1)' : 'rgba(255,255,255,0.1)';
            }
        }

        // Init Theme
        const savedTheme = localStorage.getItem('theme');
        const systemPref = window.matchMedia('(prefers-color-scheme: light)').matches ? 'light' : 'dark';
        setTheme(savedTheme || systemPref);

        themeToggle.addEventListener('click', () => {
            const current = document.documentElement.getAttribute('data-theme');
            setTheme(current === 'light' ? 'dark' : 'light');
        });

        /**
         * High Performance Canvas Particles
         */
        class ParticleSystem {
            constructor() {
                this.canvas = document.getElementById('bg-canvas');
                this.ctx = this.canvas.getContext('2d');
                this.particles = [];
                this.particleCount = 150; // Fewer but smoother particles
                this.mouse = { x: null, y: null, radius: 150 };
                this.color = document.documentElement.getAttribute('data-theme') === 'light' 
                    ? 'rgba(0,0,0,0.1)' 
                    : 'rgba(255,255,255,0.1)';
                
                this.resize();
                this.init();
                this.animate();
                
                window.addEventListener('resize', () => this.resize());
                window.addEventListener('mousemove', (e) => {
                    this.mouse.x = e.x;
                    this.mouse.y = e.y;
                });
                window.addEventListener('mouseout', () => {
                    this.mouse.x = undefined;
                    this.mouse.y = undefined;
                });
            }

            resize() {
                this.canvas.width = window.innerWidth;
                this.canvas.height = window.innerHeight;
                this.init(); // Re-init on resize to prevent stretching
            }

            init() {
                this.particles = [];
                for (let i = 0; i < this.particleCount; i++) {
                    this.particles.push({
                        x: Math.random() * this.canvas.width,
                        y: Math.random() * this.canvas.height,
                        dx: (Math.random() - 0.5) * 1, // Speed
                        dy: (Math.random() - 0.5) * 1,
                        size: Math.random() * 3 + 1
                    });
                }
            }

            animate() {
                requestAnimationFrame(() => this.animate());
                this.ctx.clearRect(0, 0, this.canvas.width, this.canvas.height);
                
                for (let i = 0; i < this.particles.length; i++) {
                    let p = this.particles[i];
                    
                    // Move
                    p.x += p.dx;
                    p.y += p.dy;

                    // Bounce
                    if (p.x < 0 || p.x > this.canvas.width) p.dx *= -1;
                    if (p.y < 0 || p.y > this.canvas.height) p.dy *= -1;

                    // Mouse Interaction
                    if (this.mouse.x != undefined) {
                        let dx = this.mouse.x - p.x;
                        let dy = this.mouse.y - p.y;
                        let distance = Math.sqrt(dx * dx + dy * dy);
                        
                        if (distance < this.mouse.radius) {
                            const forceDirectionX = dx / distance;
                            const forceDirectionY = dy / distance;
                            const force = (this.mouse.radius - distance) / this.mouse.radius;
                            const directionX = forceDirectionX * force * 3;
                            const directionY = forceDirectionY * force * 3;

                            p.x -= directionX;
                            p.y -= directionY;
                        }
                    }

                    // Draw
                    this.ctx.fillStyle = this.color;
                    this.ctx.beginPath();
                    this.ctx.arc(p.x, p.y, p.size, 0, Math.PI * 2);
                    this.ctx.fill();
                }
            }
        }

        window.particleSystem = new ParticleSystem();

        /**
         * Progress Bar Simulator
         */
        const progressBar = document.getElementById('progress-bar');
        let width = 0;
        const interval = setInterval(() => {
            if (width >= 100) {
                clearInterval(interval);
                setTimeout(() => {
                    document.querySelector('.progress-container').style.opacity = '0';
                }, 200);
            } else {
                width += Math.random() * 10;
                progressBar.style.width = Math.min(width, 100) + '%';
            }
        }, 100);

        document.getElementById('current-year').textContent = new Date().getFullYear();
    </script>
</body>
</html>
